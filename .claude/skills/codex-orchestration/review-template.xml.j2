---
name: review-task
version: 1.0.0
description: Codex agent phase-ending code review template. Read-only analysis — no code changes.
format: xml
required_variables:
  - task_id
  - phase
  - assignee
  - branch
  - commit
  - worktree_path
  - review_focus
  - review_questions
  - references
---
<atm-review id="{{ task_id }}" phase="{{ phase }}" assignee="{{ assignee }}">
  <description>Phase-ending code review. Read-only analysis — no code changes.</description>

  <branch>{{ branch }}</branch>
  <commit>{{ commit }}</commit>
  <worktree>{{ worktree_path }}</worktree>

  <review-focus>
{{ review_focus }}
  </review-focus>

  <review-questions>
{{ review_questions }}
  </review-questions>

  <references>
{{ references }}
  </references>

  <output-format>
    Structured findings report with sections:
    1. SUMMARY — one-paragraph verdict
    2. FINDINGS — numbered list, each with: severity (BLOCKER/IMPORTANT/MINOR/INFO), location (file:line), finding, recommendation
    3. EXTRACTION-READINESS — score 1-5 per module with rationale
    4. RECOMMENDED-NEXT-SPRINTS — concrete follow-up work items
  </output-format>

  <workflow>
    <step id="a">ACK this message immediately.</step>
    <step id="b">Checkout branch: `git -C {{ worktree_path }} fetch origin &amp;&amp; git -C {{ worktree_path }} checkout {{ branch }}`</step>
    <step id="c">Read the relevant source files. Do NOT make any code changes.</step>
    <step id="d">Send your structured findings report directly in the ATM message.</step>
  </workflow>
</atm-review>
